<resources>
    <style name="CalcButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:layout_gravity">fill</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">2dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Button</item>
    </style>

    <style name="ShapeAppearance.Button" parent="">
        <item name="cornerSize">7dp</item>
    </style>

    <style name="CalcButtonSci" parent="CalcButton">
        <item name="backgroundTint">@color/button_sci</item>
        <item name="android:textColor">@color/button_sci_text</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="CalcButtonNum" parent="CalcButton">
        <item name="backgroundTint">@color/button_num</item>
        <item name="android:textColor">@color/button_num_text</item>
        <item name="android:textSize">23sp</item>
    </style>

    <style name="CalcButtonOp" parent="CalcButton">
        <item name="backgroundTint">@color/button_op</item>
        <item name="android:textColor">@color/button_op_text</item>
        <item name="android:textSize">23sp</item>
    </style>

    <style name="CalcButtonDelAC" parent="CalcButton">
        <item name="backgroundTint">@color/button_del_ac</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="CalcButtonShift" parent="CalcButton">
        <item name="backgroundTint">@color/button_nav</item>
        <item name="android:textColor">@color/shift_gold</item>
        <item name="android:textSize">11sp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Pill</item>
    </style>

    <style name="CalcButtonAlpha" parent="CalcButton">
        <item name="backgroundTint">@color/button_nav</item>
        <item name="android:textColor">@color/alpha_red</item>
        <item name="android:textSize">11sp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Pill</item>
    </style>

    <style name="CalcButtonNav" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_nav</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:elevation">3dp</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Round</item>
    </style>

    <style name="ShapeAppearance.Pill" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="ShapeAppearance.Round" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>